{
  "name": "mirror-monorepo",
  "private": true,
  "description": "Mirror — Metacognition AI Professional Suite",
  "author": "RootedAI",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:packages && npm run dev --workspaces --parallel",
    "build:packages": "npm run build --workspace packages/*",
    "web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "clean": "npm run clean --workspaces"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.38",
    "@langchain/openai": "^0.0.28",
    "@supabase/supabase-js": "^2.43.0",
    "@types/dotenv": "^8.2.3",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "pdf-parse": "1.1.1",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@langchain/google-genai": "^2.1.26",
    "pg": "^8.20.0"
  }
}
